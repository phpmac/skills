{
  "env": {
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "ANTHROPIC_AUTH_TOKEN": "a",
    "ANTHROPIC_BASE_URL": "http://ai:7",
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-5-turbo",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "GLM-5.1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "GLM-5.1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)"
    ],
    "defaultMode": "default",
    "allowEditHome": false
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "hookify@phpmac-skills": true,
    "agent-sdk-dev@phpmac-skills": true,
    "commit-commands@phpmac-skills": true,
    "code-review@phpmac-skills": true,
    "feature-dev@phpmac-skills": true,
    "my-agents@phpmac-skills": true,
    "plugin-dev@phpmac-skills": true,
    "pr-review-toolkit@phpmac-skills": true,
    "security-guidance@phpmac-skills": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "phpmac-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/a/Downloads/skills"
      },
      "autoUpdate": true
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "language": "中文",
  "syntaxHighlightingDisabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.58",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": false
}
