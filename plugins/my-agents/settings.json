{
  "env": {
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "ANTHROPIC_AUTH_TOKEN": "a",
    "ANTHROPIC_BASE_URL": "http://ai:7",
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-code/kimi-k2.6-code-preview",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "GLM-5.1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)"
    ],
    "defaultMode": "default",
    "allowEditHome": false
  },
  "model": "haiku",
  "enabledPlugins": {
    "hookify@phpmac-skills": true,
    "agent-sdk-dev@phpmac-skills": true,
    "commit-commands@phpmac-skills": true,
    "code-review@phpmac-skills": true,
    "feature-dev@phpmac-skills": true,
    "my-agents@phpmac-skills": true,
    "plugin-dev@phpmac-skills": true,
    "pr-review-toolkit@phpmac-skills": true,
    "security-guidance@phpmac-skills": true,
    "discord@claude-plugins-official": true,
    "x-search@phpmac-skills": true,
    "duckdb@phpmac-skills": true
  },
  "extraKnownMarketplaces": {
    "phpmac-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/a/Downloads/skills"
      },
      "autoUpdate": true
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "language": "所有回复必须使用英文标点符号,逗号/句号/分号/引号等禁止使用中文标点符号\n代码注释必须使用中文,禁止使用英文注释,注释禁止使用中文标点符号包括，。、：！等\n禁止中途切换到英文,禁止在中文输出中混入英文句子,技术术语保持原文即可\n所有中文内容必须使用英文标点符号",
  "syntaxHighlightingDisabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.58",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": false
}
