# FOFA 网络空间测绘
# 获取地址: https://fofa.info/
FOFA_KEY=your-fofa-key

# Hunter.how 网络空间测绘
# 获取地址: https://hunter.how/
HUNTER_HOW_API_KEY=your-hunter-api-key

# Censys 网络空间测绘
# 获取地址: https://search.censys.io/
CENSYS_TOKEN=your-censys-token
CENSYS_ORGANIZATION_ID=your-censys-org-id

# NVD CVE 查询 (可选, 不配置则使用默认)
CVE_API_KEY=your-cve-api-key

# DNSDumpster 域名查询
DNSDUMPSTER_API_KEY=your-dnsdumpster-api-key

# VirusTotal 域名/文件安全查询
# 获取地址: https://www.virustotal.com/
VIRUSTOTAL_API_KEY=your-virustotal-api-key